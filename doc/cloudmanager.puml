@startuml cloudmanager

' Style and appearance settings
skinparam backgroundColor #2B2B2B
skinparam classBackgroundColor #333333
skinparam classBorderColor #FFFFFF
skinparam classFontColor #FFFFFF
skinparam classFontSize 14
skinparam arrowColor #FFFFFF
skinparam roundcorner 15
skinparam shadowing false

' CloudManager class representing AWS integration
class CloudManager {
    - AmazonEC2 ec2Client
    - AmazonCloudWatch cloudWatchClient
    - AmazonAutoScaling autoScalingClient
    - LoadBalancer balancer
    - String launchTemplateId
    - String autoScalingGroupName

    + CloudManager(LoadBalancer balancer, String accessKey, String secretKey, String region) «constructor»
    + void initializeCloudServers(int minServers, int maxServers)
    + void scaleServers(int desiredCapacity)
    + void updateServerMetricsFromCloud()
    + int getMinServers()
    + double getCloudMetric(String instanceId, String metricName)
    + void shutdown()
}

' External AWS services linked to CloudManager
CloudManager --> "1" AmazonEC2 : manages instances
CloudManager --> "1" AmazonCloudWatch : monitors metrics
CloudManager --> "1" AmazonAutoScaling : scales instances

' Relationship with LoadBalancer
LoadBalancer "1" -- "1" CloudManager : integrates with

' Explanation Note
note right of CloudManager
    "Handles cloud instance management via AWS EC2, monitors performance with CloudWatch, and scales instances dynamically."
end note

title CloudManager - AWS Integration & Scaling

@enduml
