        {
          "name": "POST Proxy Reload Example - Review Before Running",
          "description": "This validates and swaps process-local proxy route config only when proxy mode is enabled. It uses loopback placeholder upstreams and must not be used as a batch smoke unless local reload is intended.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
